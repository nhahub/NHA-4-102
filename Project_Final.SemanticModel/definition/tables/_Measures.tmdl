	measure 'Avg Skill Acquisition' = ```
			
			    AVERAGE(FactPerformanceTimeseries[Skill_Acquisition_Score])
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 84436714-cfee-464c-bfba-f3fff71e3b80

	measure 'Top Performing Department' =
			
			MAXX(
			    TOPN(1,
			        SUMMARIZE(DimEmployee, DimEmployee[Department],
			        "AvgKPI", AVERAGE(FactPerformanceTimeseries[KPI_Achievement])),
			        [AvgKPI], DESC
			    ),
			    DimEmployee[Department]
			)
		lineageTag: 038f8125-7e8f-4cd8-b11b-f7a94d39c134

	measure 'Attrition Rate' = ```
			
			    DIVIDE(
			        COUNTROWS(FILTER(FactLifecycleRetention, 
			            RELATED(DimPipelineStatus[Status_Name]) = "Terminated")),
			        COUNTROWS(FactLifecycleRetention)
			    ) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: f48cffd4-c94d-4c49-a6ba-0f90a2180302

	measure 'Avg Tenure Months' = ```
			
