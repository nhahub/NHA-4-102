	measure 'Avg Pulse Score' = ```
			
			    AVERAGE(FactMonthlyPulseTimeseries[Monthly_Pulse_Score])
			
			```
		formatString: 0.00
		lineageTag: aaac24a2-10e5-4a2d-933d-9cea44fb4784

	measure 'High Culture Band %' = ```
			
			    DIVIDE(
			        COUNTROWS(FILTER(FactMonthlyPulseTimeseries, 
			            FactMonthlyPulseTimeseries[Culture_Band] = "High")),
			        COUNTROWS(FactMonthlyPulseTimeseries)
			    ) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3da57428-63e2-4b3e-b660-4cf60338cc9d

	measure 'Lowest Pulse Month' = ```
			
			    MINX(
			        SUMMARIZE(FactMonthlyPulseTimeseries,
			            FactMonthlyPulseTimeseries[Year_Month],
			            "AvgPulse", AVERAGE(FactMonthlyPulseTimeseries[Monthly_Pulse_Score])),
			        [AvgPulse]
			    )
			```
		lineageTag: 2d01feae-1161-486e-bd6d-75429b7f507f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Pulse by Department' = ```
			
			    CALCULATE(
			        AVERAGE(FactMonthlyPulseTimeseries[Monthly_Pulse_Score]),
			        ALLEXCEPT(DimEmployee, DimEmployee[Department])
			    )
			```
		formatString: 0.00
		lineageTag: f4c8e045-f033-43e2-b947-ed40f63aa19b

