table _Measures
	lineageTag: a5494e87-5046-4612-ae1e-9a13a2d4730b

	measure 'Avg Days to Fill' = ```
			
			    AVERAGE(FactRecruitment[Days_to_Fill])
			```
		formatString: 0.00
		lineageTag: e1aeba98-8f86-4e33-96d6-5ade0862644b

	measure 'Avg Acquisition Cost' = ```
			
			    AVERAGE(FactRecruitment[Total_Acquisition_Cost])
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 550259d9-f4f8-4c39-97fc-b9f44c5d44d7

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Hire Rate' = ```
			
			VAR HiredKey =
			    CALCULATE(
			        MAX(DimPipelineStatus[Status_Key]),
			        DimPipelineStatus[Status_Name] = "Hired"
			    )
			RETURN
			DIVIDE(
			    COUNTROWS(FILTER(FactRecruitment, FactRecruitment[Status_Key] = HiredKey)),
			    COUNTROWS(FactRecruitment)
			) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 090a61fa-3a77-45e6-b7e1-7f77bc852526

	measure 'Avg LQI Hired' = ```
			
			    VAR HiredKey =
			        CALCULATE(
			            MAX(DimPipelineStatus[Status_Key]),
			            DimPipelineStatus[Status_Name] = "Hired"
			        )
			    RETURN
			    CALCULATE(
			        AVERAGE(FactRecruitment[LQI]),
			        FactRecruitment[Status_Key] = HiredKey
			    )
			```
		formatString: 0.00
		lineageTag: 9d503f99-73d3-4582-b380-62184d1c6a9e

	measure 'Avg KPI Achievement' = ```
			
			    AVERAGE(FactPerformanceTimeseries[KPI_Achievement])
			
			```
